{
  "name": "fastify-forge",
  "version": "2.2.3",
  "author": "Flavio Del Grosso",
  "license": "MIT",
  "description": "🚀 Fastify monorepo template for building scalable, high-performance Node.js web applications with ease",
  "packageManager": "pnpm@10.2.0",
  "type": "module",
  "homepage": "https://github.com/flaviodelgrosso/fastify-forge#readme",
  "bin": {
    "fastify-forge": "cli/index.js"
  },
  "files": [
    "cli"
  ],
  "keywords": [
    "fastify",
    "typescript",
    "template",
    "api",
    "server",
    "nx",
    "monorepo"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/flaviodelgrosso/fastify-forge.git"
  },
  "scripts": {
    "build": "nx run-many -t build",
    "dev": "nx run-many -t dev",
    "start": "nx run-many -t start",
    "lint": "nx run-many -t lint --",
    "typecheck": "nx run-many -t typecheck",
    "format": "prettier --write '**/*.{ts,js}'",
    "test": "nx run-many -t test",
    "clean": "nx run-many -t clean && rimraf node_modules .nx",
    "prepare": "node .husky/install.mjs",
    "syncpack:list": "npx syncpack list-mismatches",
    "syncpack:fix": "npx syncpack fix-mismatches"
  },
  "dependencies": {
    "@clack/prompts": "^0.11.0",
    "commander": "^14.0.1"
  },
  "devDependencies": {
    "@commitlint/cli": "20.5.0",
    "@commitlint/config-conventional": "20.5.0",
    "@workspace/typescript-config": "workspace:*",
    "dotenv-cli": "^11.0.0",
    "eslint": "catalog:",
    "husky": "^9.1.7",
    "prettier": "^3.7.4",
    "prettier-plugin-space-before-function-paren": "^0.0.10",
    "rimraf": "^6.0.1",
    "typescript": "catalog:",
    "nx": "22.6.5"
  },
  "engines": {
    "node": ">=24",
    "pnpm": ">=10"
  }
}

